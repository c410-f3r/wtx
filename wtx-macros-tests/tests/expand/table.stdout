#![feature(prelude_import)]
extern crate std;
#[prelude_import]
use std::prelude::rust_2021::*;
pub struct Foo {
    bar: String,
    baz: String,
}
impl Foo {
    #[doc = r" Table fields separated by commas"]
    pub(crate) const fn table_fields() -> &'static str {
        "\"foo\".bar,\"foo\".baz"
    }
}

fn main() {}
